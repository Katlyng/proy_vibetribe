{
  "name": "proy_vibetribe",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "next-themes": "^0.4.6",
      "convex": "^1.33.1",
      "better-auth": "1.5.3",
      "@convex-dev/better-auth": "^0.11.4",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @proy_vibetribe/backend dev",
    "dev:setup": "turbo -F @proy_vibetribe/backend dev:setup"
  },
  "dependencies": {
    "@proy_vibetribe/env": "workspace:*",
    "dotenv": "catalog:",
    "vite-plugin-pwa": "^1.2.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@proy_vibetribe/config": "workspace:*",
    "@types/node": "^25.6.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
